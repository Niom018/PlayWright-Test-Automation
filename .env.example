# Copy this file to .env and fill in real values. .env itself is gitignored.

BASE_URL=https://dmoneyportal.roadtocareer.net

ADMIN_EMAIL=admin@dmoney.com
ADMIN_PASSWORD=1234

SYSTEM_EMAIL=system@dmoney.com
SYSTEM_PASSWORD=1234

# A Gmail account you control, used to receive dMoney OTP emails during
# signup/login. Every test run registers a unique agent using Gmail's "+"
# alias trick (e.g. base+1721234567890@gmail.com), so all OTP emails still
# land in this one inbox regardless of which alias was used to register.
GMAIL_BASE_EMAIL=youraccount@gmail.com

# Generate this at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the Gmail account first).
# This is NOT your normal Gmail password.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Phone number of an existing customer already in the system, used for the
# step 7 agent-to-customer deposit.
EXISTING_CUSTOMER_PHONE=01700000000
